CREATE (:__mg_vertex__:`Concept` {__mg_id__: 547, `id`: "Personal data", `description`: "Personal data or personal information means any information about you that enables you to be identified personally. It covers obvious information such as your name and contact details, but it also covers less obvious information such as identification numbers, electronic location data and other online identifiers that can be linked with such information in order to identify you. It does not include data where the identity has been removed (anonymous data).", `source`: "scraped", `timestamp`: "2025-12-05T15:18:40.070745"});
